@page "/account/access-denied"

<PageTitle>Access Denied — XIPE</PageTitle>

<section style="min-height:80vh;display:flex;align-items:center;justify-content:center;background:var(--x-surface-dark,#1A1A1A);">
    <div style="text-align:center;">
        <h1 style="font-family:var(--x-font-heading);color:var(--x-accent);font-size:3rem;">403</h1>
        <h2 style="font-family:var(--x-font-heading);color:var(--x-white);margin-bottom:1rem;">ACCESS DENIED</h2>
        <p class="xbody" style="color:var(--x-grey-400);margin-bottom:2rem;">No tienes permisos para ver esta página.</p>
        <a href="/" class="xbtn xbtn--outline">Volver al inicio</a>
    </div>
</section>
