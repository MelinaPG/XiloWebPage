@page "/onboarding/step-6"

<PageTitle>Your Dashboard — XIPE</PageTitle>

<div class="ob-page">
    <OnboardingStepper CurrentStep="6" />

    <section class="ob-content">
        <div class="ob-content__inner xcontainer">

            <div class="ob-left">
                <span class="ob-step-badge">Step 6 of 6</span>
                <h1 class="ob-headline">YOUR SITE IS<br />COMING<br />SOON.</h1>
                <p class="ob-sub">Our team is working on your project. You'll get updates via email and your personal dashboard.</p>
            </div>

            <div class="ob-card">
                <div class="ob-card__head">
                    <h2 class="ob-card__title">Your Project Dashboard</h2>
                </div>

                <div class="ob-card__body">
                    <div class="ob-dashboard-grid">
                        <!-- Timeline -->
                        <div class="ob-dashboard-card">
                            <div class="ob-dashboard-card__icon" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                    <line x1="16" y1="2" x2="16" y2="6"/>
                                    <line x1="8" y1="2" x2="8" y2="6"/>
                                    <line x1="3" y1="10" x2="21" y2="10"/>
                                </svg>
                            </div>
                            <h3 class="ob-dashboard-card__title">Timeline</h3>
                            <p class="ob-dashboard-card__text">Project kicks off within 5 business days</p>
                        </div>

                        <!-- Project Manager -->
                        <div class="ob-dashboard-card">
                            <div class="ob-dashboard-card__icon" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                            </div>
                            <h3 class="ob-dashboard-card__title">Project Manager</h3>
                            <p class="ob-dashboard-card__text">Will contact you within 24 hours</p>
                        </div>

                        <!-- Stay Updated -->
                        <div class="ob-dashboard-card">
                            <div class="ob-dashboard-card__icon" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                </svg>
                            </div>
                            <h3 class="ob-dashboard-card__title">Stay Updated</h3>
                            <p class="ob-dashboard-card__text">Check your email for updates and next steps</p>
                        </div>
                    </div>

                    <div class="ob-info-box">
                        <p class="ob-info-box__text">
                            Welcome to XILO! We're excited to bring your vision to life. You'll receive a unique dashboard URL via email shortly. In the meantime, keep an eye on your inbox for project updates.
                        </p>
                    </div>

                    <a href="/admin" class="ob-cta" style="display:block;text-align:center;">
                        Go to My Dashboard →
                    </a>

                    <a href="mailto:Contac@xipetechnology.com" class="ob-link-secondary">
                        Need help? Contact us
                    </a>
                </div>
            </div>

        </div>
    </section>
</div>
