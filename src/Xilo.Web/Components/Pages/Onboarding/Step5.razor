@page "/onboarding/step-5"

<PageTitle>Book a Call — XIPE</PageTitle>

<div class="ob-page">
    <OnboardingStepper CurrentStep="5" />

    <section class="ob-content">
        <div class="ob-content__inner xcontainer">

            <div class="ob-left">
                <span class="ob-step-badge">Step 5 of 6</span>
                <h1 class="ob-headline">PICK A TIME<br />THAT WORKS<br />FOR YOU.</h1>
                <p class="ob-sub">This 45-minute call is where the magic starts — we'll align on your vision, goals, and timeline.</p>
            </div>

            <div class="ob-card">
                <div class="ob-card__header">
                    <p class="ob-card__title">Schedule Your Kickoff Call</p>
                    <p class="ob-card__subtitle">30-minute session · Video call</p>
                </div>

                <div class="ob-card__widget">
                    <div style="min-width:320px;min-height:660px;display:flex;align-items:center;justify-content:center;border:1px dashed var(--x-mid);border-radius:var(--x-radius);color:var(--x-neutral);font-size:.875rem;padding:2rem;text-align:center;">
                        Calendly widget will be embedded here
                    </div>
                </div>

                <div style="text-align:center;padding:1.5rem 0;">
                    <a href="/onboarding/step-6" class="ob-cta" style="display:inline-block;">
                        Continue →
                    </a>
                </div>
            </div>

        </div>
    </section>
</div>
