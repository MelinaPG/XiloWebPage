@page "/onboarding/step-3"

<PageTitle>You're In! — XIPE</PageTitle>

<div class="ob-page">
    <OnboardingStepper CurrentStep="3" />

    <section class="ob-content">
        <div class="ob-content__inner xcontainer">

            <div class="ob-left">
                <span class="ob-step-badge">Step 3 of 6</span>
                <h1 class="ob-headline">WELCOME<br />TO<br />XILO.</h1>
                <p class="ob-sub">Your payment was confirmed.<br />Now let's get your brand assets ready.</p>
            </div>

            <div class="ob-card">
                <div class="ob-card__head">
                    <div class="ob-card__check">
                        <div class="ob-card__check-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#88D98D" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <div class="ob-card__check-line" aria-hidden="true"></div>
                    </div>
                    <h2 class="ob-card__title">You're all set!</h2>
                </div>

                <div class="ob-confirm-email">
                    <span class="ob-confirm-email__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </span>
                    <p class="ob-confirm-email__text">
                        Confirmation sent to <strong>your email</strong>
                    </p>
                </div>

                <div class="ob-summary" role="table" aria-label="Order summary">
                    <div class="ob-summary__row" role="row">
                        <span class="ob-summary__label">Payment</span>
                        <span class="ob-summary__value ob-summary__value--accent">$950 USD · Confirmed</span>
                    </div>
                    <div class="ob-summary__row" role="row">
                        <span class="ob-summary__label">Project start</span>
                        <span class="ob-summary__value">Within 5 business days</span>
                    </div>
                    <div class="ob-summary__row" role="row">
                        <span class="ob-summary__label">Project manager</span>
                        <span class="ob-summary__value">Will reach out within 24h</span>
                    </div>
                </div>

                <p class="ob-card__context">
                    Next, share your brand materials — logos, fonts, photos, inspiration — so we can hit the ground running.
                </p>

                <div class="ob-card__actions">
                    <a href="/onboarding/step-4" class="ob-cta" style="display:block;text-align:center;">
                        Upload Your Assets →
                    </a>
                    <a href="mailto:Contac@xipetechnology.com" class="ob-link-secondary">
                        Have questions? Contact us
                    </a>
                </div>
            </div>

        </div>
    </section>
</div>
