@page "/propuesta/sitio-corporativo"

<PageTitle>Propuesta — Sitio Web Corporativo | XIPE Technology</PageTitle>

<div class="pp">
    <!-- Hero / Cover -->
    <section class="pp-cover">
        <div class="pp-cover__grain" aria-hidden="true"></div>
        <div class="pp-cover__inner xcontainer">
            <div class="pp-cover__badge">
                <img src="assets/xilo-logo.png" alt="XILO" class="pp-cover__logo" />
                <span class="pp-cover__badge-sep" aria-hidden="true"></span>
                <span class="pp-cover__badge-label">Propuesta Comercial</span>
            </div>
            <h1 class="pp-cover__title">
                SITIO WEB<br />
                CORPORATIVO<br />
                <span class="pp-cover__title-accent">&amp; PLATAFORMA</span><br />
                DIGITAL
            </h1>
            <p class="pp-cover__date">Marzo 2026</p>
        </div>
        <div class="pp-cover__scroll" aria-hidden="true">
            <span></span>
        </div>
    </section>

    <!-- Objetivo -->
    <section class="pp-section pp-section--light" id="objetivo">
        <div class="xcontainer pp-container">
            <div class="pp-section__num" aria-hidden="true">01</div>
            <div class="pp-section__body">
                <h2 class="pp-h2">Objetivo</h2>
                <p class="pp-lead">
                    Desarrollar un sitio web corporativo moderno y escalable que represente
                    al grupo empresarial y sus empresas asociadas, permitiendo comunicar su
                    propuesta de valor, centralizar información y habilitar futuras
                    funcionalidades como pedidos y aplicaciones específicas.
                </p>
                <p class="pp-body">
                    El proyecto se desarrollará en <strong>fases progresivas</strong> para permitir
                    lanzar rápidamente la presencia digital y posteriormente integrar nuevas
                    funcionalidades.
                </p>
            </div>
        </div>
    </section>

    <!-- Alcance -->
    <section class="pp-section pp-section--dark" id="alcance">
        <div class="xcontainer pp-container">
            <div class="pp-section__num pp-section__num--light" aria-hidden="true">02</div>
            <div class="pp-section__body">
                <h2 class="pp-h2 pp-h2--light">Alcance del Proyecto</h2>

                <!-- Sitio Corporativo -->
                <div class="pp-scope-block">
                    <h3 class="pp-h3 pp-h3--light">
                        <span class="pp-h3__tag">2.1</span>
                        Sitio Corporativo del Grupo
                    </h3>
                    <p class="pp-body pp-body--light">
                        Se desarrollará el sitio principal del grupo con las siguientes secciones:
                    </p>
                    <ul class="pp-checklist">
                        <li>
                            <span class="pp-checklist__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            Página principal
                        </li>
                        <li>
                            <span class="pp-checklist__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            Visión
                        </li>
                        <li>
                            <span class="pp-checklist__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            Empresas del grupo
                        </li>
                        <li>
                            <span class="pp-checklist__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            Historia
                        </li>
                        <li>
                            <span class="pp-checklist__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            Contacto
                        </li>
                    </ul>
                    <p class="pp-body pp-body--light pp-body--muted">
                        Este sitio funcionará como el centro de comunicación institucional.
                    </p>
                </div>

                <!-- Landing Pages -->
                <div class="pp-scope-block">
                    <h3 class="pp-h3 pp-h3--light">
                        <span class="pp-h3__tag">2.2</span>
                        Landing Pages de Empresas del Grupo
                    </h3>
                    <p class="pp-body pp-body--light">
                        Cada empresa tendrá su propia página dentro del sitio con su identidad y servicios.
                    </p>

                    <div class="pp-companies">
                        <div class="pp-company-card">
                            <div class="pp-company-card__accent" aria-hidden="true"></div>
                            <h4 class="pp-company-card__name">Inmobiliaria</h4>
                            <ul class="pp-company-card__list">
                                <li>Oportunidades</li>
                                <li>Información de contacto</li>
                            </ul>
                        </div>
                        <div class="pp-company-card">
                            <div class="pp-company-card__accent pp-company-card__accent--blue" aria-hidden="true"></div>
                            <h4 class="pp-company-card__name">Power Gas</h4>
                            <ul class="pp-company-card__list">
                                <li>Ubicaciones</li>
                                <li>Atención a clientes</li>
                            </ul>
                        </div>
                        <div class="pp-company-card">
                            <div class="pp-company-card__accent pp-company-card__accent--green" aria-hidden="true"></div>
                            <h4 class="pp-company-card__name">Multilíquidos — Power Gas</h4>
                            <ul class="pp-company-card__list">
                                <li>Acerca de nosotros</li>
                                <li>Contacto</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Consideraciones -->
    <section class="pp-section pp-section--light" id="consideraciones">
        <div class="xcontainer pp-container">
            <div class="pp-section__num" aria-hidden="true">03</div>
            <div class="pp-section__body">
                <h2 class="pp-h2">Consideraciones</h2>

                <div class="pp-notice">
                    <div class="pp-notice__icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                    </div>
                    <div>
                        <p class="pp-notice__title">Fecha de entrega: 16 de Marzo</p>
                        <p class="pp-notice__body">
                            Por los tiempos recortados, desarrollar un branding en forma no es posible.
                            Sin embargo, si no tienes marca desarrollada de alguna de las empresas,
                            nuestro equipo de diseño creará una <strong>imagen neutra profesional</strong>
                            y similar a las otras del grupo, y posteriormente integrar el branding de la empresa.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Propuesta Económica -->
    <section class="pp-section pp-section--pricing" id="precio">
        <div class="xcontainer pp-container">
            <div class="pp-section__num pp-section__num--light" aria-hidden="true">04</div>
            <div class="pp-section__body">
                <h2 class="pp-h2 pp-h2--light">Propuesta Económica</h2>

                <div class="pp-pricing-table">
                    <div class="pp-pricing-row">
                        <div class="pp-pricing-row__desc">
                            <span class="pp-pricing-row__label">Diseño y desarrollo del sitio web</span>
                            <span class="pp-pricing-row__sub">Sitio corporativo + 3 landing pages de empresas</span>
                        </div>
                        <div class="pp-pricing-row__amount">$14,000 <span>MXN</span></div>
                    </div>
                    <div class="pp-pricing-row">
                        <div class="pp-pricing-row__desc">
                            <span class="pp-pricing-row__label">Hosting y dominios</span>
                            <span class="pp-pricing-row__sub">Servicio anual · Incluye SSL y soporte</span>
                        </div>
                        <div class="pp-pricing-row__amount">$3,000 <span>MXN</span></div>
                    </div>
                    <div class="pp-pricing-total">
                        <span class="pp-pricing-total__label">Total</span>
                        <span class="pp-pricing-total__amount">$17,000 <span>MXN</span></span>
                    </div>
                </div>

                <div class="pp-cta-block">
                    <a href="/onboarding" class="pp-cta">Aceptar Propuesta →</a>
                    <p class="pp-cta-block__note">
                        Al aceptar, iniciaremos el proceso de desarrollo inmediatamente.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer mini -->
    <footer class="pp-footer">
        <div class="xcontainer">
            <img src="assets/xilo-logo.png" alt="XILO" class="pp-footer__logo" />
            <p class="pp-footer__text">
                <a href="mailto:Contac@xipetechnology.com">Contac@xipetechnology.com</a>
            </p>
            <p class="pp-footer__legal">XIPE Technology · Propuesta confidencial</p>
        </div>
    </footer>
</div>
