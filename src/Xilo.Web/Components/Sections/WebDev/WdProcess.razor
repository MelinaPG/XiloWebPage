<section class="wd-process">
    <div class="xcontainer">
        <div class="wd-process__header">
            <h2 class="wd-process__headline" data-i18n-html="process.headline">
                A GUIDED &amp; SECURE<br />PROCESS FOR YOU
            </h2>
            <p class="xbody-lg wd-process__sub" data-i18n-html="process.sub">
                Get your website live in just <em>7 days</em>
            </p>
        </div>

        <div class="wd-process__track">

            <div class="wd-process__step">
                <div class="wd-process__step-circle">
                    <span class="xlabel">01</span>
                </div>
                <div class="wd-process__step-connector"></div>
                <div class="wd-process__step-content">
                    <h4 class="wd-process__step-title xlabel" data-i18n="step1.title">CREATE YOUR ACCOUNT</h4>
                    <p class="xbody" data-i18n="step1.desc">Sign up on our platform to start the process.</p>
                </div>
            </div>

            <div class="wd-process__step">
                <div class="wd-process__step-circle">
                    <span class="xlabel">02</span>
                </div>
                <div class="wd-process__step-connector"></div>
                <div class="wd-process__step-content">
                    <h4 class="wd-process__step-title xlabel" data-i18n="step2.title">MAKE YOUR PAYMENT</h4>
                    <p class="xbody" data-i18n="step2.desc">A secure one-time payment to kick off your project.</p>
                </div>
            </div>

            <div class="wd-process__step">
                <div class="wd-process__step-circle">
                    <span class="xlabel">03</span>
                </div>
                <div class="wd-process__step-connector"></div>
                <div class="wd-process__step-content">
                    <h4 class="wd-process__step-title xlabel" data-i18n="step3.title">SCHEDULE YOUR CALL</h4>
                    <p class="xbody" data-i18n="step3.desc">A discovery call to understand your vision and goals.</p>
                </div>
            </div>

            <div class="wd-process__step">
                <div class="wd-process__step-circle">
                    <span class="xlabel">04</span>
                </div>
                <div class="wd-process__step-connector"></div>
                <div class="wd-process__step-content">
                    <h4 class="wd-process__step-title xlabel" data-i18n="step4.title">DESIGN &amp; CONTENT</h4>
                    <p class="xbody" data-i18n="step4.desc">We present up to 3 design proposals for your approval.</p>
                </div>
            </div>

            <div class="wd-process__step">
                <div class="wd-process__step-circle">
                    <span class="xlabel">05</span>
                </div>
                <div class="wd-process__step-connector"></div>
                <div class="wd-process__step-content">
                    <h4 class="wd-process__step-title xlabel" data-i18n="step5.title">REVISIONS</h4>
                    <p class="xbody" data-i18n="step5.desc">We refine every detail until your site is exactly what you need.</p>
                </div>
            </div>

            <div class="wd-process__step wd-process__step--last">
                <div class="wd-process__step-circle wd-process__step-circle--final">
                    <span class="xlabel">06</span>
                </div>
                <div class="wd-process__step-content">
                    <h4 class="wd-process__step-title xlabel" data-i18n="step6.title">LAUNCH</h4>
                    <p class="xbody" data-i18n="step6.desc">Your site goes live. Ready, published, and online.</p>
                </div>
            </div>

        </div>
    </div>
</section>
